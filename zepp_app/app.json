{
  "configVersion": "v2",
  "app": {
    "appId": 1106330,
    "appName": "DuDu",
    "appType": "app",
    "version": {
      "code": 3,
      "name": "1.0.2"
    },
    "icon": "icon.png",
    "vender": "mrdiaez",
    "description": "Voice memo recorder"
  },
  "permissions": [
    "data:os.mic.record",
    "data:os.device.info",
    "device:os.mic"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "targets": {
    
    "bip6": {
      "platforms": [
        { "name": "bip6v1", "deviceSource": 9765120 },
        { "name": "bip6v2", "deviceSource": 9765121 },
        { "name": "bip6v3", "deviceSource": 10158337 }
      ],
      "module": {
        "page": {
          "pages": [
            "page/gt/home/index.page",
            "page/gt/home/audiolist.page"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      }
    }
  },
  "defaultLanguage": "en-US",
  "i18n": {
    "en-US": {
      "appName": "DuDu"
    },
    "it-IT": {
      "appName": "DuDu"
    }
  }
}
